# Environment files
.env

# WordPress - Ignora uploads ma mantieni codice versionabile
# La directory uploads/ deve esistere come mountpoint per il bind di runtime
# (cfr docker-compose.yml AIUCD_UPLOADS_DIR), quindi versioniamo solo il .gitkeep
wordpress/wp-content/uploads/*
!wordpress/wp-content/uploads/.gitkeep
wordpress/wp-config.php
# wordpress/.htaccess: versionato (regole WP standard), serve da bootstrap
# se il file viene perso (es. ripristino macchina) altrimenti tutti i
# permalink restituiscono 404. WP puo' rigenerarlo da Admin > Permalink.

# WordPress core files - opzionale: puoi scegliere se versionare o no
# wordpress/wp-admin/
# wordpress/wp-includes/
# wordpress/index.php
# wordpress/wp-*.php
# !wordpress/wp-content/

# Database volumes  
database/

# Backups
backups/
*.sql

# Logs
logs/
*.log

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Playwright screenshots
.playwright-mcp/

# Docker
docker-compose.override.yml